{
  "name": "@jadujoel/uniform-audio-param",
  "module": "dist/audio-param-polyfill.js",
  "main": "dist/audio-param-polyfill.js",
  "types": "dist/audio-param-polyfill.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/audio-param-polyfill.js",
      "types": "./dist/audio-param-polyfill.d.ts"
    },
    "./manual": {
      "import": "./dist/audio-param-polyfill-manual.js",
      "types": "./dist/audio-param-polyfill-manual.d.ts"
    }
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.1",
  "scripts": {
    "build": "bun build audio-param-polyfill.ts audio-param-polyfill-manual.ts --outdir dist --minify && bunx tsc --declaration --emitDeclarationOnly --outDir dist audio-param-polyfill.ts audio-param-polyfill-manual.ts",
    "test": "bun test-polyfill.ts",
    "test:all": "bun test-audio-params.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "playwright": "1.59.1"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "files": [
    "dist",
    "README.md",
    "audio-param-polyfill.ts",
    "audio-param-polyfill-manual.ts"
  ]
}
